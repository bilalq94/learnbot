rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // USERS
    // ============================================================
    match /users/{userId} {

      // Anyone authenticated can read user docs (needed for leaderboard,
      // classroom member lookups, username uniqueness checks, referral queries).
      allow read: if request.auth != null;

      // New user document — created at signup.
      // Allow create only for the user's own doc.
      allow create: if request.auth != null
                    && request.auth.uid == userId;

      // Updates — owner only, with protected fields.
      // isPro, trialStartDate, stripeSessionId, upgradeDate are SERVER-ONLY
      // (set by /api/verify-payment and /api/webhook via Admin SDK).
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && !isChangingProtectedFields();
    }

    function isChangingProtectedFields() {
      // Block client-side writes to monetisation & trust fields.
      // The Admin SDK bypasses rules, so server endpoints are unaffected.
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasAny([
        'isPro',
        'trialStartDate',
        'stripeSessionId',
        'upgradeDate',
        'createdAt'
      ]);
    }

    // ============================================================
    // PAYMENTS  (server-only — written by webhook / verify-payment)
    // ============================================================
    match /payments/{paymentId} {
      allow read:  if false;   // No client reads needed
      allow write: if false;   // Admin SDK only
    }

    // ============================================================
    // CLASSROOMS
    // ============================================================
    match /classrooms/{classroomId} {

      // Any authenticated user can read (needed to join via code,
      // view class leaderboard, load classroom data).
      allow read: if request.auth != null;

      // Any authenticated user can create a classroom (teacher flow).
      allow create: if request.auth != null
                    && request.resource.data.teacherId == request.auth.uid;

      // Only the teacher who created it can update (add goals,
      // challenges, update student list).
      // Students are added via update by the teacher OR by a student
      // joining — so we allow update if the user is the teacher
      // OR is adding themselves to the studentIds array.
      allow update: if request.auth != null
                    && (resource.data.teacherId == request.auth.uid
                        || isStudentJoining(classroomId));

      allow delete: if request.auth != null
                    && resource.data.teacherId == request.auth.uid;
    }

    function isStudentJoining(classroomId) {
      // Allow a student to add themselves (and only themselves) to a classroom.
      // They can modify studentIds and students arrays but nothing else security-critical.
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(['studentIds', 'students']);
    }

    // ============================================================
    // ORGANIZATIONS
    // ============================================================
    match /organizations/{orgId} {

      allow read: if request.auth != null;

      allow create: if request.auth != null;

      // Only org admins (creator) can update.
      allow update: if request.auth != null
                    && (resource.data.createdBy == request.auth.uid
                        || request.auth.uid in resource.data.adminIds);

      allow delete: if request.auth != null
                    && resource.data.createdBy == request.auth.uid;
    }

    // ============================================================
    // FEEDBACK  (write-only from clients, read from console/admin)
    // ============================================================
    match /feedback/{feedbackId} {
      allow read:   if false;  // Admin console only
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }

    // ============================================================
    // DEFAULT — deny everything else
    // ============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
