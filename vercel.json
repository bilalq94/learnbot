{
  "functions": {
    "api/coach.js": {
      "maxDuration": 30
    },
    "api/webhook.js": {
      "maxDuration": 10
    },
    "api/verify-payment.js": {
      "maxDuration": 15
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
